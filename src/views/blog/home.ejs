<% const featuredPosts = Array.isArray(posts) ? posts : []; %>
<% const sidebarCategories = Array.isArray(categories) ? categories : []; %>
<% const sidebarTags = Array.isArray(tags) ? tags : []; %>

<section class="space-y-8">
  <div class="wp-panel-strong overflow-hidden">
    <div class="grid gap-0 lg:grid-cols-[minmax(0,1.25fr)_minmax(280px,0.75fr)]">
      <div class="relative overflow-hidden px-6 py-8 sm:px-8 sm:py-10 lg:px-10 lg:py-12">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(34,113,177,0.16),_transparent_34%),radial-gradient(circle_at_bottom_left,_rgba(19,94,150,0.12),_transparent_32%)]"></div>
        <div class="relative space-y-5">
          <div class="flex flex-wrap items-center gap-2 text-[0.65rem] font-semibold uppercase tracking-[0.34em] text-brand-600">
            <span class="rounded-full border border-brand-200 bg-brand-50 px-3 py-1">Modern CMS Blog</span>
            <span class="rounded-full border border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] px-3 py-1 text-slate-500">Responsive editorial hub</span>
          </div>

          <div class="max-w-3xl">
            <h1 class="text-3xl font-semibold leading-tight tracking-tight text-slate-950 sm:text-4xl lg:text-5xl">
              Konten modern, dashboard admin, dan workflow editorial yang rapi.
            </h1>
            <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg dark:text-slate-300">
              Platform lengkap untuk menulis, mengelola artikel, dan tumbuh bersama audiens dengan pengalaman yang tetap nyaman di mobile.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href="/admin/login" class="wp-btn wp-btn-primary">
              <i class="fas fa-arrow-right-to-bracket"></i>
              Login Admin
            </a>
            <a href="/admin/login" class="wp-btn wp-btn-secondary">
              <i class="fas fa-pen-nib"></i>
              Mulai menulis
            </a>
          </div>

          <div class="flex flex-wrap gap-2">
            <span class="wp-badge">Node.js</span>
            <span class="wp-badge">Express</span>
            <span class="wp-badge">Prisma</span>
            <span class="wp-badge">Tailwind</span>
          </div>
        </div>
      </div>

      <div class="border-t border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] px-6 py-8 sm:px-8 lg:border-l lg:border-t-0 lg:px-8 lg:py-12">
        <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
          <div class="rounded-3xl border border-[color:var(--wp-border)] bg-[color:var(--wp-surface)] p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-600">Artikel</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950"><%= featuredPosts.length %></p>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Konten terbaru yang siap dibaca.</p>
          </div>
          <div class="rounded-3xl border border-[color:var(--wp-border)] bg-[color:var(--wp-surface)] p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-600">Kategori</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950"><%= sidebarCategories.length %></p>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Topik yang tertata rapi.</p>
          </div>
          <div class="rounded-3xl border border-[color:var(--wp-border)] bg-[color:var(--wp-surface)] p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-600">Tag</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950"><%= sidebarTags.length %></p>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Pencarian topik lebih cepat.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-8 lg:grid-cols-[minmax(0,1.45fr)_minmax(280px,0.75fr)] lg:items-start">
    <div class="space-y-6">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.32em] text-brand-600">Artikel terbaru</p>
          <h2 class="mt-2 text-2xl font-semibold text-slate-950">Bacaan terbaru</h2>
        </div>
        <p class="text-sm text-slate-500 dark:text-slate-400">Card otomatis turun ke satu kolom di layar kecil.</p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
        <% if (featuredPosts.length) { %>
          <% featuredPosts.forEach((post) => { %>
            <article class="group wp-panel overflow-hidden h-full transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
              <a href="/posts/<%= post.slug %>" class="block">
                <div class="aspect-[16/10] overflow-hidden bg-[color:var(--wp-surface-2)]">
                  <% if (post.featuredImage) { %>
                    <img src="<%= post.featuredImage %>" alt="<%= post.title %>" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
                  <% } else { %>
                    <div class="flex h-full w-full items-center justify-center text-slate-400">
                      <i class="fas fa-image text-3xl"></i>
                    </div>
                  <% } %>
                </div>
              </a>

              <div class="flex h-full flex-col p-5">
                <div class="flex flex-wrap items-center gap-2 text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-brand-600">
                  <span><%= post.status ? post.status.toUpperCase() : "PUBLISHED" %></span>
                  <% if (post.readingTime) { %>
                    <span class="rounded-full border border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] px-2.5 py-1 tracking-normal text-slate-500"><%= post.readingTime %> min</span>
                  <% } %>
                </div>

                <h3 class="mt-3 text-lg font-semibold leading-snug text-slate-950 transition-colors group-hover:text-brand-600 dark:text-white">
                  <a href="/posts/<%= post.slug %>"><%= post.title %></a>
                </h3>

                <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
                  <%= post.subheadline || post.excerpt || (post.content ? post.content.replace(/<[^>]*>/g, "").slice(0, 140) : "Tidak ada ringkasan tersedia.") %>
                </p>

                <div class="mt-5 flex flex-wrap items-center gap-3 border-t border-[color:var(--wp-border)] pt-4 text-xs text-slate-500 dark:text-slate-400">
                  <span><i class="far fa-clock mr-1"></i><%= post.readingTime || "2" %> min read</span>
                  <span><i class="fas fa-eye mr-1"></i><%= post.viewCount || 0 %> views</span>
                </div>
              </div>
            </article>
          <% }) %>
        <% } else { %>
          <div class="sm:col-span-2 xl:col-span-3 rounded-3xl border border-dashed border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] p-8 text-sm text-slate-500 dark:text-slate-400">
            Belum ada artikel. Silakan login ke dashboard untuk menulis konten pertama.
          </div>
        <% } %>
      </div>

      <% if (typeof pagination !== "undefined" && pagination && pagination.totalPages > 1) { %>
        <%- include('../partials/pagination', { pagination }) %>
      <% } %>
    </div>

    <aside class="space-y-6 lg:sticky lg:top-28 lg:self-start">
      <div class="wp-panel p-6">
        <div class="sidebar-title border-none pb-0 text-brand-600">
          <i class="fas fa-folder-tree"></i> Kategori
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          <% if (sidebarCategories.length) { %>
            <% sidebarCategories.forEach((category) => { %>
              <a href="/categories/<%= category.slug %>" class="wp-btn wp-btn-pill px-3 py-2 text-sm"><%= category.name %></a>
            <% }) %>
          <% } else { %>
            <span class="wp-btn wp-btn-pill px-3 py-2 text-sm opacity-70">Tidak ada kategori</span>
          <% } %>
        </div>
      </div>

      <div class="wp-panel p-6">
        <div class="sidebar-title border-none pb-0 text-brand-600">
          <i class="fas fa-hashtag"></i> Tags
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          <% if (sidebarTags.length) { %>
            <% sidebarTags.forEach((tag) => { %>
              <a href="/tags/<%= tag.slug %>" class="wp-btn wp-btn-pill px-3 py-2 text-sm">#<%= tag.name %></a>
            <% }) %>
          <% } else { %>
            <span class="wp-btn wp-btn-pill px-3 py-2 text-sm opacity-70">Belum ada tag</span>
          <% } %>
        </div>
      </div>

      <div class="wp-panel p-6">
        <div class="sidebar-title border-none pb-0 text-brand-600">
          <i class="fas fa-shield-halved"></i> Insight
        </div>
        <ul class="mt-4 space-y-3 text-sm text-slate-600 dark:text-slate-300">
          <li class="flex items-center gap-3 rounded-2xl border border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] px-4 py-3">
            <i class="fas fa-bolt text-brand-600"></i>
            Responsive grid di semua ukuran layar
          </li>
          <li class="flex items-center gap-3 rounded-2xl border border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] px-4 py-3">
            <i class="fas fa-mobile-screen text-brand-600"></i>
            Header dan kartu yang nyaman di mobile
          </li>
          <li class="flex items-center gap-3 rounded-2xl border border-[color:var(--wp-border)] bg-[color:var(--wp-surface-2)] px-4 py-3">
            <i class="fas fa-image text-brand-600"></i>
            Thumbnail dan konten tetap proporsional
          </li>
        </ul>
      </div>
    </aside>
  </div>
</section>
